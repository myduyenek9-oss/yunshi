APP_TIMEZONE=Asia/Shanghai
APP_PORT=8088
# 通过 Nginx 反向代理时保持 127.0.0.1；直接用公网 IP 临时测试时改为 0.0.0.0。
APP_BIND_HOST=127.0.0.1
WEB_ACCESS_TOKEN=change-this-private-token

# Set MOCK_AI=true for local smoke tests without consuming OpenAI quota.
MOCK_AI=false
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# Optional: set this when using an OpenAI-compatible proxy/relay, usually ending with /v1.
# Leave empty when using official OpenAI directly.
OPENAI_BASE_URL=

DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
DINGTALK_SECRET=SECxxxxxxxx

BIRTH_CALENDAR=solar
BIRTH_DATE=1990-01-01
BIRTH_TIME=08:00
BIRTH_PLACE=城市名
BIRTH_GENDER=male

DAILY_PUSH_CRON=0 8 * * *
DATA_DIR=data


